<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Joining_Date_Not_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Joining_Date__c &gt; TODAY()</errorConditionFormula>
    <errorMessage>&quot;Joining Date cannot be in the future.&quot;</errorMessage>
</ValidationRule>
